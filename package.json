{
  "name": "dicode-relay",
  "version": "0.1.1",
  "description": "OAuth broker + WebSocket relay server for dicode",
  "keywords": [
    "dicode",
    "oauth",
    "oauth-broker",
    "websocket",
    "webhook-relay",
    "tunnel",
    "grant"
  ],
  "homepage": "https://github.com/dicode-ayo/dicode-relay#readme",
  "bugs": {
    "url": "https://github.com/dicode-ayo/dicode-relay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dicode-ayo/dicode-relay.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "dicode-ayo",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dicode-relay": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "STATUS_PASSWORD=admin tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^5.0.1",
    "grant": "^5.4.22",
    "js-yaml": "^4.1.1",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}

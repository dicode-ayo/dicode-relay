# dicode-relay environment variables
# Copy to .env and fill in the values for local development.
# In production, set these as real environment variables — do not use .env files.
# Load for local dev: node --env-file=.env dist/index.js

# ---------------------------------------------------------------------------
# Service config
# ---------------------------------------------------------------------------

# Port to listen on (default: 5553)
PORT=5553

# Public base URL — used in relay welcome messages and as Grant's origin.
# In production: https://relay.dicode.app
BASE_URL=https://relay.dicode.app

# ---------------------------------------------------------------------------
# TLS (optional — skip if TLS is terminated by Cloudflare or nginx)
# ---------------------------------------------------------------------------

# Path to PEM-encoded TLS certificate
TLS_CERT_FILE=

# Path to PEM-encoded TLS private key
TLS_KEY_FILE=

# ---------------------------------------------------------------------------
# Provider credentials
# Set only the providers you have registered OAuth apps for.
# PKCE-only providers (marked below) do not require a client_secret.
# ---------------------------------------------------------------------------

# GitHub — https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack — https://api.slack.com/apps (PKCE-only, no secret needed)
SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET not needed (PKCE-only)

# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify — https://developer.spotify.com/dashboard (PKCE-only)
SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET not needed (PKCE-only)

# Linear — https://linear.app/settings/api (PKCE-only)
LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET not needed (PKCE-only)

# Discord — https://discord.com/developers/applications (PKCE-only)
DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET not needed (PKCE-only)

# GitLab — https://gitlab.com/-/user_settings/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Airtable — https://airtable.com/create/oauth
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=

# Notion — https://www.notion.so/my-integrations (no PKCE, uses client_secret)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Confluence (Atlassian) — https://developer.atlassian.com/console/myapps/ (PKCE-only)
CONFLUENCE_CLIENT_ID=
# CONFLUENCE_CLIENT_SECRET not needed (PKCE-only)

# Salesforce — https://login.salesforce.com/setup/secur/RemoteAccessAuthorizationPage.apexp (PKCE-only)
SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET not needed (PKCE-only)

# Stripe — https://dashboard.stripe.com/settings/connect (no PKCE, uses client_secret)
STRIPE_CLIENT_ID=
STRIPE_CLIENT_SECRET=

# Microsoft Office 365 — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
OFFICE365_CLIENT_ID=
OFFICE365_CLIENT_SECRET=

# Microsoft Azure AD — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
